{
  "private": true,
  "name": "@earth-app/rain",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "create:activity": "bun src/index.ts --type=activity",
    "create:prompt": "bun src/index.ts --type=prompt",
    "create:event": "bun src/index.ts --type=event",
    "create:article": "bun src/index.ts --type=article",
    "create:all": "bun run create:activity && bun run create:prompt && bun run create:event && bun run create:article",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "commander": "^14.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0"
  },
  "lint-staged": {
    "*.{js,ts,json,yml}": "prettier --write"
  }
}
