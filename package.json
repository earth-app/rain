{
  "private": true,
  "name": "@earth-app/rain",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "photo:activity": "bun src/photos/index.ts --type=activity",
    "photo:prompt": "bun src/photos/index.ts --type=prompt",
    "photo:event": "bun src/photos/index.ts --type=event",
    "photo:article": "bun src/photos/index.ts --type=article",
    "photo:all": "bun run photo:activity && bun run photo:prompt && bun run photo:event && bun run photo:article",
    "video:prompt": "bun src/videos/generate-prompt.ts",
    "video:studio": "bunx remotion studio src/videos/index.ts --public-dir src/assets",
    "upload:prompt": "bun src/upload.ts --type=prompt",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@remotion/cli": "4.0.451",
    "canvas": "^3.2.3",
    "commander": "^14.0.3",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.5",
    "remotion": "4.0.451"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0"
  },
  "lint-staged": {
    "*.{js,ts,json,yml}": "prettier --write"
  }
}
